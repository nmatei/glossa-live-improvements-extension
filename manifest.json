{
  "name": "Glossa.live improvements",
  "version": "1.0.0",
  "description": "Glossa.live improvements ✨",
  "manifest_version": 3,
  "author": "Matei Nicolae",
  "background": {
    "service_worker": "views/background.js"
  },
  "action": {},
  "permissions": ["activeTab", "storage", "clipboardWrite"],
  "content_scripts": [
    {
      "matches": [
        "https://glossa.live/*"
      ],
      "js": ["views/icons/icons.js", "views/common/utilities.js", "views/common/tooltip/tooltip.js", "views/common/simplePrompt/simplePrompt.js"],
      "css": ["views/common/colors.css", "views/common/tooltip/tooltip.css", "views/common/simplePrompt/simplePrompt.css", "views/common/actions.css"],
      "run_at": "document_end"
    },
    {
      "matches": ["https://glossa.live/*"],
      "js": ["views/glossa/index.js"],
      "css": ["views/glossa/overrides.css"]
    }
  ],
  "icons": {
    "16": "views/icons/icon-16.png",
    "48": "views/icons/icon-48.png",
    "128": "views/icons/icon-128.png"
  }
}
